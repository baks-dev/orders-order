{% set item_identifier = item.vars.value.const|trans %}

    {# @var itemSign \BaksDev\Products\Sign\Repository\AllProductSignByOrder\AllProductSignByOrderResult #}

{% if products_sign_items[item_identifier] is defined %}

    {% set itemSign = products_sign_items[item_identifier] %}

    <div class="text-center p-2">
        {{ product_sign_status(itemSign.status) }}
    </div>

    {# короткий код маркировки в системе «Честный знак» #}

    <div class="text-primary text-truncate text-nowrap pointer copy me-3 text-start"
         data-copy="{{ itemSign.smallCode }}"
         style="max-width: 130px; min-width: 130px;"
         data-bs-toggle="tooltip"
         data-bs-placement="bottom"
         data-bs-delay='{"show":600,"hide":100}'
         title="Скопировать короткий код"
    >
        <span class="me-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-braces"
                 viewBox="0 0 16 16">
              <path d="M2.114 8.063V7.9c1.005-.102 1.497-.615 1.497-1.6V4.503c0-1.094.39-1.538 1.354-1.538h.273V2h-.376C3.25 2 2.49 2.759 2.49 4.352v1.524c0 1.094-.376 1.456-1.49 1.456v1.299c1.114 0 1.49.362 1.49 1.456v1.524c0 1.593.759 2.352 2.372 2.352h.376v-.964h-.273c-.964 0-1.354-.444-1.354-1.538V9.663c0-.984-.492-1.497-1.497-1.6M13.886 7.9v.163c-1.005.103-1.497.616-1.497 1.6v1.798c0 1.094-.39 1.538-1.354 1.538h-.273v.964h.376c1.613 0 2.372-.759 2.372-2.352v-1.524c0-1.094.376-1.456 1.49-1.456V7.332c-1.114 0-1.49-.362-1.49-1.456V4.352C13.51 2.759 12.75 2 11.138 2h-.376v.964h.273c.964 0 1.354.444 1.354 1.538V6.3c0 .984.492 1.497 1.497 1.6"/>
            </svg>
        </span>

        {{ itemSign.getMarking }}
    </div>

    {# полный код маркировки в системе «Честный знак» #}

    <div class="text-primary text-truncate text-nowrap pointer copy me-3"
         data-copy="{{ itemSign.bigCode }}"
         style="max-width: 135px; min-width: 135px;"
         data-bs-toggle="tooltip"
         data-bs-placement="bottom"
         data-bs-delay='{"show":600,"hide":100}'
         title="Скопировать полный код маркировки в системе «Честный знак»"
    >

        <span class="me-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 class="bi bi-braces-asterisk" viewBox="0 0 16 16">
              <path fill-rule="evenodd"
                    d="M1.114 8.063V7.9c1.005-.102 1.497-.615 1.497-1.6V4.503c0-1.094.39-1.538 1.354-1.538h.273V2h-.376C2.25 2 1.49 2.759 1.49 4.352v1.524c0 1.094-.376 1.456-1.49 1.456v1.299c1.114 0 1.49.362 1.49 1.456v1.524c0 1.593.759 2.352 2.372 2.352h.376v-.964h-.273c-.964 0-1.354-.444-1.354-1.538V9.663c0-.984-.492-1.497-1.497-1.6M14.886 7.9v.164c-1.005.103-1.497.616-1.497 1.6v1.798c0 1.094-.39 1.538-1.354 1.538h-.273v.964h.376c1.613 0 2.372-.759 2.372-2.352v-1.524c0-1.094.376-1.456 1.49-1.456v-1.3c-1.114 0-1.49-.362-1.49-1.456V4.352C14.51 2.759 13.75 2 12.138 2h-.376v.964h.273c.964 0 1.354.444 1.354 1.538V6.3c0 .984.492 1.497 1.497 1.6M7.5 11.5V9.207l-1.621 1.621-.707-.707L6.792 8.5H4.5v-1h2.293L5.172 5.879l.707-.707L7.5 6.792V4.5h1v2.293l1.621-1.621.707.707L9.208 7.5H11.5v1H9.207l1.621 1.621-.707.707L8.5 9.208V11.5z"/>
            </svg>
        </span>
        Код маркировки
    </div>


    {# номер грузовой таможенной диклорации #}

    <div class="text-primary text-truncate text-nowrap pointer copy text-start"
         data-copy="{{ itemSign.number }}"
         style="max-width: 150px; min-width: 150px;"
         data-bs-toggle="tooltip"
         data-bs-placement="bottom"
         data-bs-delay='{"show":600,"hide":100}'
         title="Скопировать номер грузовой таможенной диклорации"
    >

        <span class="me-1">
